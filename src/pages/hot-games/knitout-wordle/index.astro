---
import Layout from '../../../layouts/Layout.astro';
// ✅ 如果 @ 没配，请换成：import { WORDS } from "../../../constants/wordlist";
import { WORDS } from "@/constants/wordlist";
import Breadcrumbs from '@/components/Breadcrumbs.astro';

export const prerender = true;

const START_DATE_ISO = '2026-03-03';
const DAY_MS = 24 * 60 * 60 * 1000;

const msFromISODateUTC = (iso: string): number => Date.parse(`${iso}T00:00:00.000Z`);
const toISODateFromMs = (ms: number): string => new Date(ms).toISOString().split('T')[0];
const todayUtcMs = (): number => {
  const now = new Date();
  return Date.UTC(now.getUTCFullYear(), now.getUTCMonth(), now.getUTCDate());
};

const startMs = msFromISODateUTC(START_DATE_ISO);
const todayMs = todayUtcMs();

const maxDays = Math.floor((todayMs - startMs) / DAY_MS);
const total = Math.min(WORDS.length, Math.max(0, maxDays + 1));

const datesAsc = Array.from({ length: total }).map((_, i) => toISODateFromMs(startMs + i * DAY_MS));
const datesDesc = [...datesAsc].reverse();

const latest = datesDesc[0];
const yesterday = datesDesc[1];
const recent30 = datesDesc.slice(0, 30);

type MonthGroup = { month: string; dates: string[] };
const monthGroups = datesAsc.reduce((acc: MonthGroup[], d) => {
  const month = d.slice(0, 7);
  const last = acc[acc.length - 1];
  if (!last || last.month !== month) acc.push({ month, dates: [d] });
  else last.dates.push(d);
  return acc;
}, []);

const title = "KnitOut Wordle — Daily Hints, Strategy, and Answers (Archive)";
const description =
  "Your KnitOut Wordle hub: daily hints, quick strategy signals (vowels, repeats, rare letters), common mistakes, and a full archive by date.";

const canonical = "https://www.knitout.net/hot-games/knitout-wordle";

// JSON-LD: ItemList（最近 10 个）+ FAQPage
const itemList = {
  "@context": "https://schema.org",
  "@type": "ItemList",
  "name": "KnitOut Wordle daily puzzles (recent)",
  "itemListElement": recent30.slice(0, 10).map((d, i) => ({
    "@type": "ListItem",
    "position": i + 1,
    "url": `${canonical}${d}`
  }))
};

const faq = {
  "@context": "https://schema.org",
  "@type": "FAQPage",
  "mainEntity": [
    {
      "@type": "Question",
      "name": "Where can I find today’s KnitOut Wordle answer?",
      "acceptedAnswer": {
        "@type": "Answer",
        "text": "Open the latest daily page. The answer is hidden behind a click-to-reveal section so you can stop before spoilers."
      }
    },
    {
      "@type": "Question",
      "name": "Do you publish future dates?",
      "acceptedAnswer": {
        "@type": "Answer",
        "text": "No. We only publish puzzles up to the current day to avoid placeholder pages and keep the archive clean."
      }
    },
    {
      "@type": "Question",
      "name": "What do ‘signals’ mean (vowels, repeats, rare letters)?",
      "acceptedAnswer": {
        "@type": "Answer",
        "text": "Signals are non-spoiler facts about the day’s word that guide strategy: vowel count, repeated letters, and whether rare letters (J/Q/X/Z) appear."
      }
    }
  ]
};
---

<Layout title={title} description={description} canonical={canonical}>
  <script type="application/ld+json" set:html={JSON.stringify(itemList)} slot="head" />
  <script type="application/ld+json" set:html={JSON.stringify(faq)} slot="head" />

  <main id="top" class="hub">
    <div class="container">
      
        <div class="topbar">
            <Breadcrumbs 
              items={[
                { label: 'Hot Games', href: '/hot-games' },
              ]}
            >
              <span slot="last-item" class="pill">KnitOut Wordle</span>
            </Breadcrumbs>
          </div>

      <!-- HERO -->
      <header class="hero card">
        <div class="hero-left">
          <h1>KnitOut Wordle</h1>
          <p class="lead">
            This is the main hub for <strong>KnitOut Wordle hints</strong>, <strong>today’s answer</strong> (hidden by default),
            and the full daily archive. If you’re stuck, start with the latest puzzle and use the non-spoiler “signals” below to solve faster.
          </p>

          <div class="cta">
            <a class="btn btn-primary" href={latest ? `/hot-games/knitout-wordle/${latest}` : "/hot-games/knitout-wordle"}>
              Open latest puzzle
            </a>
            {yesterday && <a class="btn" href={`/hot-games/knitout-wordle/${yesterday}`}>Yesterday</a>}
            <a class="btn" href="/hot-games">← Hot Games</a>
          </div>

          <div class="pills">
            <span class="pill">Updated daily</span>
            <span class="pill">{total} puzzles</span>
            {latest && <span class="pill">Latest: {latest}</span>}
          </div>
        </div>

        <div class="hero-right">
          <div class="mini">
            <h2 class="mini-title">What’s on each daily page?</h2>
            <ul class="mini-list">
              <li><strong>Hints</strong> (non-spoiler)</li>
              <li><strong>Quick signals</strong> (vowels / repeats / rare letters)</li>
              <li><strong>Winning strategy checklist</strong></li>
              <li><strong>Common mistakes</strong></li>
              <li><strong>Answer</strong> (click to reveal)</li>
            </ul>
          </div>
        </div>
      </header>

      <!-- LONG-TAIL SECTIONS -->
      <section class="card section">
        <h2>KnitOut Wordle hints today (without spoilers)</h2>
        <p>
          Most “answer today” pages are thin. Our daily pages are designed for solving: you get a layered hint system
          that doesn’t immediately spoil the word. You’ll see signals like vowel count, repeated-letter risk,
          and rare-letter presence (J/Q/X/Z) — then a strategy path for your next 2 guesses.
        </p>
        <div class="callout">
          <strong>Fast path:</strong> open the latest page → read “Today’s Hints” → use “Quick Signals” → only reveal the answer if needed.
        </div>
      </section>

      <section class="grid">
        <section class="card section">
          <h2>Quick signals (vowels, repeats, rare letters)</h2>
          <p>
            These signals are the highest ROI “long-tail” helpers because they change your guessing plan immediately:
          </p>
          <ul>
            <li><strong>Vowels:</strong> low-vowel days reward consonant-heavy probes (and watching for Y).</li>
            <li><strong>Repeated letters:</strong> stop assuming uniqueness; verify duplicates by guess 3.</li>
            <li><strong>Rare letters:</strong> if stuck, probe J/Q/X/Z instead of brute forcing patterns.</li>
          </ul>
          <p class="muted">
            (These are non-spoiler facts — they guide strategy without revealing the word.)
          </p>
        </section>

        <section class="card section">
          <h2>Common mistakes players make</h2>
          <ul>
            <li>Committing to a pattern too early instead of eliminating letters broadly.</li>
            <li>Missing a duplicate letter and “proving” the wrong candidate set.</li>
            <li>Over-testing vowels on consonant-heavy days (or ignoring vowels on vowel-heavy days).</li>
            <li>Wasting guesses on exotic letters when the day is clearly common-letter heavy.</li>
          </ul>
          <div class="callout small">
            Tip: your daily page includes a “Common Mistakes Today” section tailored to that word’s structure.
          </div>
        </section>
      </section>

      <section class="card section">
        <h2>Best starting words (data-first)</h2>
        <p>
          A good starter isn’t “a vibe” — it’s coverage. The best openers usually maximize high-frequency letters and spread vowels.
          We’ll publish a dedicated guide with starter tiers and why they work.
        </p>

        <!-- 未来内页入口：先占位，后续你做内页就把链接补上 -->
        <div class="linkgrid">
          <a class="linkcard" href="/hot-games/knitout-wordle">Starter words guide (coming)</a>
          <a class="linkcard" href="/hot-games/knitout-wordle">Double-letter strategy (coming)</a>
          <a class="linkcard" href="/hot-games/knitout-wordle">Hard mode tips (coming)</a>
          <a class="linkcard" href="/hot-games/knitout-wordle">Pattern checklist (coming)</a>
        </div>
      </section>

      <!-- FIND + RECENT -->
      <section class="card section">
        <h2>Find a puzzle by date</h2>
        <p>Type a date like <code>2026-03-05</code>, or jump by month.</p>

        <input id="dateFilter" class="input" type="text" placeholder="Search date (YYYY-MM-DD)..." inputmode="numeric" autocomplete="off" />

        <div class="months">
          {monthGroups.map((g) => (
            <a class="chip" href={`#m-${g.month}`}>{g.month}</a>
          ))}
        </div>

        <h3 class="subhead">Recent 30</h3>
        <ul class="recent" id="recentList">
          {recent30.map((d) => (
            <li class="recent-row" data-date={d}>
              <a href={`/hot-games/knitout-wordle/${d}`}>{d}</a>
              <span>Hints • Signals • Strategy • Answer</span>
            </li>
          ))}
        </ul>
      </section>

      <!-- ARCHIVE -->
      <section class="card section">
        <h2>Full archive</h2>
        {monthGroups.slice().reverse().map((g) => (
          <section class="month" id={`m-${g.month}`}>
            <div class="month-head">
              <h3>{g.month}</h3>
              <a class="toplink" href="#top">Back to top</a>
            </div>
            <ul class="month-grid">
              {g.dates.slice().reverse().map((d) => (
                <li class="tile" data-date={d}>
                  <a href={`/hot-games/knitout-wordle/${d}`}>{d}</a>
                </li>
              ))}
            </ul>
          </section>
        ))}
      </section>

      <!-- FAQ -->
      <section class="card section faq">
        <h2>FAQ</h2>
        <details>
          <summary>Does this page spoil the answer?</summary>
          <p>No — the hub explains strategy. Answers are only on daily pages and are hidden behind click-to-reveal.</p>
        </details>
        <details>
          <summary>Why is this hub so long?</summary>
          <p>Because search engines (and users) reward pages that genuinely explain the topic, not just a list of links.</p>
        </details>
        <details>
          <summary>Why don’t you publish future dates?</summary>
          <p>Publishing placeholders often leads to thin pages and soft-404 signals. We only publish up to today.</p>
        </details>
      </section>

    </div>
  </main>

  <script is:inline>
    const input = document.getElementById('dateFilter');
    const nodes = document.querySelectorAll('[data-date]');

    function applyFilter() {
      const q = (input && input.value ? input.value.trim().toLowerCase() : '');
      if (!q) {
        nodes.forEach(n => n.style.removeProperty('display'));
        return;
      }
      nodes.forEach(n => {
        const d = (n.getAttribute('data-date') || '').toLowerCase();
        n.style.display = d.includes(q) ? '' : 'none';
      });
    }

    if (input) input.addEventListener('input', applyFilter);
  </script>

  <style>
    .hub{ padding:2.25rem 0 4rem; background:#f9fafb; }
    .container{ max-width:1100px; margin:0 auto; padding:0 1.25rem; }
    .card{ background:#fff; border:1px solid #e5e7eb; border-radius:18px; box-shadow:0 4px 10px rgba(0,0,0,.06); padding:1.15rem 1.15rem; margin-top:1rem; }
    h1{ font-size:2.25rem; font-weight:900; margin:0 0 .6rem; }
    h2{ font-size:1.35rem; font-weight:900; margin:0 0 .55rem; }
    h3{ font-size:1.1rem; font-weight:900; margin:1rem 0 .55rem; }
    .lead{ color:#4b5563; line-height:1.75; max-width:80ch; margin:0; }
    .cta{ display:flex; gap:.75rem; flex-wrap:wrap; margin-top:1rem; }
    .btn{ display:inline-flex; align-items:center; justify-content:center; padding:.65rem 1rem; border-radius:999px; border:1px solid #e5e7eb; background:#fff; text-decoration:none; font-weight:900; color:#111827; }
    .btn-primary{ border:none; background:linear-gradient(135deg,#3b82f6,#1d4ed8); color:#fff; }
    .pills{ display:flex; gap:.5rem; flex-wrap:wrap; margin-top:.9rem; }
    .pill{ font-size:.78rem; font-weight:900; color:#2563eb; background:rgba(59,130,246,.12); padding:.35rem .65rem; border-radius:999px; }

    .grid{ display:grid; grid-template-columns: 1fr 1fr; gap:1rem; }
    @media (max-width: 900px){ .grid{ grid-template-columns:1fr; } }

    .callout{ margin-top:.85rem; background:rgba(59,130,246,.10); border:1px solid rgba(59,130,246,.18); padding:.85rem 1rem; border-radius:14px; }
    .callout.small{ font-size:.95rem; color:#374151; }
    .muted{ color:#6b7280; }

    .linkgrid{ display:grid; grid-template-columns:repeat(auto-fill,minmax(240px,1fr)); gap:.6rem; margin-top:.85rem; }
    .linkcard{ border:1px solid #eef2f7; border-radius:14px; padding:.8rem .9rem; text-decoration:none; font-weight:900; color:#2563eb; background:#fff; }

    .input{ width:100%; padding:.85rem 1rem; border:1px solid #e5e7eb; border-radius:12px; font-weight:900; margin:.75rem 0; }
    .months{ display:flex; gap:.5rem; flex-wrap:wrap; margin-bottom:.5rem; }
    .chip{ text-decoration:none; font-weight:900; color:#2563eb; background:rgba(59,130,246,.10); padding:.35rem .6rem; border-radius:999px; border:1px solid rgba(59,130,246,.18); }

    .subhead{ margin-top:1rem; }
    .recent{ list-style:none; padding:0; margin:.6rem 0 0; display:grid; gap:.5rem; }
    .recent-row{ border:1px solid #eef2f7; border-radius:14px; padding:.75rem .9rem; display:flex; align-items:center; justify-content:space-between; gap:.75rem; }
    .recent-row a{ text-decoration:none; font-weight:900; color:#2563eb; }
    .recent-row span{ color:#6b7280; font-weight:800; font-size:.9rem; }

    .month{ margin-top:1.25rem; }
    .month-head{ display:flex; align-items:baseline; justify-content:space-between; gap:1rem; }
    .toplink{ color:#6b7280; text-decoration:none; font-weight:900; }
    .toplink:hover{ text-decoration:underline; }
    .month-grid{ list-style:none; padding:0; margin:.6rem 0 0; display:grid; grid-template-columns:repeat(auto-fill,minmax(180px,1fr)); gap:.55rem; }
    .tile{ border:1px solid #eef2f7; border-radius:14px; padding:.65rem .85rem; background:#fff; }
    .tile a{ text-decoration:none; font-weight:900; color:#2563eb; }

    .faq details{ border-top:1px solid #eef2f7; padding:.75rem 0; }
    .faq details:first-of-type{ border-top:none; }
    .faq summary{ cursor:pointer; font-weight:900; }
    .faq p{ margin:.5rem 0 0; color:#4b5563; }
    code{ background:#f3f4f6; padding:0 .35rem; border-radius:6px; }
  </style>
</Layout>
